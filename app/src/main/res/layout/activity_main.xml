<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp"
    android:focusable="false"
    android:focusableInTouchMode="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 PICK &amp; PLACE CONTROLLER"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#000000"
            android:background="#4CAF50"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Connection Status -->
        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FF0000"
            android:layout_marginBottom="16dp" />

        <!-- Connection Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Connect to Arduino"
                android:textColor="@color/white"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnect"
                android:textColor="@color/white"
                android:backgroundTint="#F44336"
                android:enabled="false" />
        </LinearLayout>

        <!-- Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ AUTOMATED PICK &amp; PLACE ℹ️\nPress buttons in sequence:\nA → B → X → Y → START (reset)\nEach button runs a specific movement"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#1976D2"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Xbox Controller Help -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎮 PICK &amp; PLACE SEQUENCES 🎮\n━━━━━━━━━━━━━━━━━━━━━━━━━━\n🎯 A Button = APPROACH object\n✊ B Button = GRAB object\n📍 X Button = DROP position\n👐 Y Button = RELEASE object\n🏠 START Button = RESET home"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#000000"
            android:background="#BBDEFB"
            android:padding="16dp"
            android:layout_marginBottom="12dp" />

        <!-- Servo Status Display -->
        <TextView
            android:id="@+id/servoStatusDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎮 SERVO POSITIONS 🎮\n\nS0 Base (Port 1): 90°\nS1 Shoulder (Port 4): 90°\nS2 Elbow (Port 7): 90°\nS3 Wrist (Port 8): 90°\nS4 Wrist Rot (Port 11): 90°\nS5 Gripper (Port 15): 90°"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:padding="16dp"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <!-- Servo 0 - Base -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servo 0 - Base → PORT 1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnServo0Min"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Min (0°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnServo0Max"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Max (180°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#FF9800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <EditText
                        android:id="@+id/etServo0Position"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Position (0-180)"
                        android:inputType="number"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnServo0Set"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Servo 1 - Shoulder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F3E5F5"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servo 1 - Shoulder → PORT 4"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnServo1Min"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Min (0°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnServo1Max"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Max (180°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#FF9800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <EditText
                        android:id="@+id/etServo1Position"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Position (0-180)"
                        android:inputType="number"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnServo1Set"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Servo 2 - Elbow -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF3E0"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servo 2 - Elbow → PORT 7"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnServo2Min"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Min (0°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnServo2Max"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Max (180°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#FF9800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <EditText
                        android:id="@+id/etServo2Position"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Position (0-180)"
                        android:inputType="number"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnServo2Set"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Servo 3 - Wrist -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servo 3 - Wrist → PORT 8"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnServo3Min"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Min (0°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnServo3Max"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Max (180°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#FF9800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <EditText
                        android:id="@+id/etServo3Position"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Position (0-180)"
                        android:inputType="number"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnServo3Set"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Servo 4 - Wrist Rotation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FCE4EC"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servo 4 - Wrist Rotation → PORT 11"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnServo4Min"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Min (0°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnServo4Max"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Max (180°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#FF9800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <EditText
                        android:id="@+id/etServo4Position"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Position (0-180)"
                        android:inputType="number"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnServo4Set"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Servo 5 - Gripper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF9C4"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Servo 5 - Gripper → PORT 15"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <Button
                        android:id="@+id/btnServo5Min"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Min (0°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#2196F3"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btnServo5Max"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Max (180°)"
                        android:textColor="@color/white"
                        android:backgroundTint="#FF9800" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <EditText
                        android:id="@+id/etServo5Position"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Position (0-180)"
                        android:inputType="number"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnServo5Set"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SET"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Quick Reference -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 PORT MAPPING REFERENCE\nS0→P1 | S1→P4 | S2→P7\nS3→P8 | S4→P11 | S5→P15"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#000000"
            android:background="#E0E0E0"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>